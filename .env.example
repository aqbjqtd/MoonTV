# ================================================================
# MoonTV 环境变量配置模板
# ================================================================
# 说明：
# 1. 复制此文件为 .env.local
# 2. 修改相应的配置值
# 3. 重启应用生效

# ------------------------------------------
# 🔒 核心安全配置 (必须配置)
# ------------------------------------------

# 管理员密码 - 用于登录验证 (必须设置，请修改为强密码)
PASSWORD=your_secure_password_here

# 管理员用户名 - 站长账户 (可选，用于数据库模式)
USERNAME=admin

# ------------------------------------------
# 📦 存储配置
# ------------------------------------------

# 存储类型: localstorage | redis | upstash | d1
NEXT_PUBLIC_STORAGE_TYPE=localstorage

# Redis 配置 (当 STORAGE_TYPE=redis 时)
# REDIS_URL=redis://localhost:6379

# Upstash 配置 (当 STORAGE_TYPE=upstash 时)
# UPSTASH_URL=your_upstash_url
# UPSTASH_TOKEN=your_upstash_token

# ------------------------------------------
# 🌐 网站基础配置
# ------------------------------------------

# 网站名称
NEXT_PUBLIC_SITE_NAME=MoonTV

# 网站公告
ANNOUNCEMENT=本网站仅提供影视信息搜索服务，所有内容均来自第三方网站。本站不存储任何视频资源，不对任何内容的准确性、合法性、完整性负责。

# 是否允许用户注册
NEXT_PUBLIC_ENABLE_REGISTER=false

# 搜索最大页数
NEXT_PUBLIC_SEARCH_MAX_PAGE=5

# ------------------------------------------
# 🎭 豆瓣代理配置 (可选)
# ------------------------------------------

# 豆瓣代理类型: direct | cors-anywhere | custom
NEXT_PUBLIC_DOUBAN_PROXY_TYPE=direct

# 豆瓣代理地址 (当类型为 custom 时)
# NEXT_PUBLIC_DOUBAN_PROXY=https://your-proxy.com

# 豆瓣图片代理类型: direct | cors-anywhere | custom  
NEXT_PUBLIC_DOUBAN_IMAGE_PROXY_TYPE=direct

# 豆瓣图片代理地址 (当类型为 custom 时)
# NEXT_PUBLIC_DOUBAN_IMAGE_PROXY=https://your-image-proxy.com

# ------------------------------------------
# 🛡️ 安全与功能配置
# ------------------------------------------

# 禁用黄色过滤器
NEXT_PUBLIC_DISABLE_YELLOW_FILTER=false

# Docker 环境标识 (自动检测)
# DOCKER_ENV=true

# ------------------------------------------
# 🚀 部署配置 (可选)
# ------------------------------------------

# 服务器主机名 (部署时使用)
# HOSTNAME=localhost

# 服务器端口 (部署时使用)
# PORT=3000

# Node.js 环境
NODE_ENV=production